# Copie para .env e ajuste os valores
# Nunca commite o .env no git

# DSN do PostgreSQL local
# Formato: postgresql://usuario:senha@host:porta/banco
RPIMON_DSN=postgresql://rpimon:TROCAR_SENHA@localhost:5432/monitoramento

# Nível de log: DEBUG, INFO, WARNING, ERROR
RPIMON_LOG_LEVEL=INFO

# Caminho do arquivo de log (deixe vazio para stderr)
RPIMON_LOG_FILE=/var/log/rpi-monitor/collector.log
